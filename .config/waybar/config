{
    "height": 30, // Waybar height (to be removed for auto height)
    "layer": "top", // Waybar at top layer
    "margin-top": 6,
    "margin-left": 10,
    "margin-bottom": 0,
    "margin-right": 10,
    "spacing": 5, // Gaps between modules (4px)
    "modules-left": ["custom/launcher", "cpu", "memory","custom/FUApps", "wlr/workspaces"],
    "modules-center": ["custom/spotify"],
    "modules-right": ["backlight","custom/bluetooth", "pulseaudio", "network", "battery", "clock", "custom/power-menu"],
    "wlr/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "1": "пДС",
        "2": "пДС",
        "3": "пДС",
        "4": "пДС",
        "5": "пДС",
        "urgent": "пБ™",
        "active": "пДС",
        "default": "пДС"
      }
    },
    "hyprland/window": {
        "format": "{}"
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
	"format": "<span color='#bf616a'>пАЧ </span>{:%I:%M %p}",	
        "format-alt": "<span color='#bf616a'>пБ≥ </span>{:%a %b %d}",
        
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    },

    "cpu": {
      "interval": 10,
      "format": "пШ¶ {}%",
      "max-length": 10,
      "on-click": "",
    },
    "memory": {
        "interval": 30,
        "format": "пШ™ {}%",
        "format-alt":"пС≤ {used:0.1f}G",
        "max-length": 10,
    },
    "backlight": {
        "device": "DP-1",
        "format": "{icon} {percent}%",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
        "on-click": "",
    },
    "network": {
        "format-wifi": "п™® {signalStrength}%",
        "format-ethernet": "пЫњ wired",
        "format-disconnected": "п™©",
        "on-click": "~/.config/waybar/scripts/rofi-wifi-menu.sh",
        "format-disconnected": "Disconnected пБ± ",
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "пА• пКФ {volume}%",
        "format-bluetooth-muted": "пЪ© пКФ",
        "format-muted": "п™А",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },

    "custom/bluetooth": {
        "format": "пКФ",
	"on-click": "bash ~/.config/waybar/scripts/rofi-bluetooth", 

    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-critical": "{icon} {capacity}%",
      "format-charging": "<span font-family='Font Awesome 6 Free'>пГІ</span> {capacity}%",
      "format-plugged": "пЗ¶  {capacity}%",
      "format-alt": "{icon} {time}",
      "format-full": "пЗ¶  {capacity}%",
      "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
    },   "custom/FUApps": {
    "format": "у±УЯ",
    "on-click": "bash ~/.config/scripts/FUApps/FUApps.sh",
    },
   "custom/spotify": {
    "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py --player spotify",
    "format": "{} пЖЉ ",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-double-click-right": "playerctl next",
    "on-scroll-down": "playerctl previous",
    },
    "custom/power-menu": {
        "format": " <span color='#6a92d7'>вПї </span>",
        "on-click": "bash ~/.config/waybar/scripts/power-menu/powermenu.sh",
    }, 
    "custom/launcher": {
	"format": " <span color='#6a92d7'>пМГ </span>",	
        "on-click": "rofi -show drun",
    },
}

